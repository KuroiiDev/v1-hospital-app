{
  "version": 2,
  "framework": null,
  "outputDirectory":"...",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "/img/(.*)",
      "dest": "public/img/"
    },
    {
      "src": "/images/(.*)",
      "dest": "images/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "public/assets/"
    },
    {
      "src": "/css/(.*)",
      "dest": "public/css/"
    },
    {
      "src": "/js/(.*)",
      "dest": "public/js/"
    },
    {
      "src": "/build/(.*)",
      "dest": "public/build/"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "CACHE_STORE": "array",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",

    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "VIEW_COMPILED_PATH": "/tmp"
  }
}